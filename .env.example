# E-commerce template environment example
# Copy this file as .env for local development.
# In Render, create the same variables in Environment.
# Never commit the real .env file.

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
STORE_NAME=Demo Store
SERVICE_NAME=ecommerce-template-api
APP_SECRET=change_this_to_a_long_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_a_long_password
# Optional: server-to-server only. Do not expose it in the frontend.
ADMIN_API_KEY=

# Frontend / API
# Local:
CLIENT_ORIGIN=http://127.0.0.1:5173
VITE_API_URL=http://127.0.0.1:3001/api
PUBLIC_APP_URL=http://127.0.0.1:3001

# Render:
# CLIENT_ORIGIN=https://your-store.onrender.com
# VITE_API_URL=/api
# PUBLIC_APP_URL=https://your-store.onrender.com

# WhatsApp / phone in international format, without + or spaces.
VITE_WHATSAPP_NUMBER=5490000000000
# Internal admin order notification fallback.
ADMIN_WHATSAPP_NUMBER=5490000000000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@YOUR_CLUSTER.mongodb.net/your-store?retryWrites=true&w=majority
MONGODB_DB_NAME=your-store

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=your-store-products

# Transactional email with Resend
# For quick tests you can use onboarding@resend.dev.
# For production, verify your own domain in Resend.
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Demo Store <onboarding@resend.dev>
